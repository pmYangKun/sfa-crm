# ==========================================================
# SFA CRM 生产环境配置模板
# 复制为 .env.production 后填入真实值，绝不要 commit 到 git
# ==========================================================

# 运行环境（启动校验严格度由此驱动）
# - production: 启动时强校验，错误配置 → 拒绝启动
# - dev: 宽松，缺密钥 fallback 到 dev key + warning
ENV=production

# ----- 必填密钥 -----

# JWT 签名密钥（≥ 32 字符随机串）
# 生成命令: openssl rand -base64 48
JWT_SECRET=__REPLACE_ME_WITH_REAL_SECRET_AT_LEAST_32_CHARS__

# LLM API Key 加密的 Fernet 密钥（base64，44 字符）
# 生成命令:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# ⚠️⚠️⚠️ 极其重要 ⚠️⚠️⚠️
# 丢失此 key = 所有 llm_config.api_key 永久无法解密！
# 必须独立备份到与数据库备份不同的安全位置。
# rotate 必须先解密老数据再用新 key 重新加密（spec 003 提供 rotate 工具）。
LLM_KEY_FERNET_KEY=__REPLACE_ME_WITH_FERNET_KEY__

# ----- 域名与跨域 -----

# 允许的浏览器源（多个用逗号分隔，无空格）
# 生产必须是具体域名，不能用 *
CORS_ORIGINS=https://sfacrm.pmyangkun.com

# ----- 数据库 -----

# SQLite 文件路径（绝对路径推荐）
DATABASE_URL=sqlite:////var/lib/sfa-crm/sfa_crm.db

# ----- LLM Provider（选填，首次部署便利 fallback；后续走 admin UI） -----

# 主存储是 DB 中的 llm_config.api_key（加密）；env 中的是首次部署的便利 fallback
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# ----- Webhook secret（spec 001 既有）-----

WEBHOOK_SECRET=__REPLACE_ME_WITH_WEBHOOK_SECRET__
